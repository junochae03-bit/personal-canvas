{
  "name": "personal-canvas",
  "version": "1.0.0",
  "private": true,
  "description": "NAI Studio — NovelAI image generation PWA (static, GitHub Pages)",
  "type": "module",
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "check": "node --check sw.js && node -e \"const fs=require('fs'),re=/<script(?![^>]*\\\\bsrc=)[^>]*>([\\\\s\\\\S]*?)<\\/script>/g,h=fs.readFileSync('index.html','utf8');let m,j='';while((m=re.exec(h)))j+='\\\\n//---\\\\n'+m[1];fs.writeFileSync('/tmp/_inline.js',j);\" && node --check /tmp/_inline.js"
  },
  "engines": {
    "node": ">=18"
  }
}
